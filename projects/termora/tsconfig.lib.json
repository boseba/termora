{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
      "rootDir": "./src",
      "outDir": "../../out-tsc/lib",
      "declaration": true,
      "declarationMap": true,
      "sourceMap": true,
      "inlineSources": true,
      "types": []
  },
  "include": [
      "src/**/*.ts"
  ],
  "exclude": [
      "src/**/*.spec.ts",
      "src/**/*.test.ts"
  ],
  "angularCompilerOptions": {
      "compilationMode": "partial"
  }
}